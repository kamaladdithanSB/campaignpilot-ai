// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  orders    Order[]
  snapshots SegmentSnapshot[]
  createdAt DateTime @default(now())
}

model Order {
  id          String   @id @default(uuid())
  amount      Float
  orderDate   DateTime @default(now())
  createdAt   DateTime @default(now())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
}

model Campaign {
  id                String           @id @default(uuid())
  title             String
  status            String           // DRAFT, QUEUED, EXECUTING, COMPLETED
  strategy          String           // JSON string of CampaignStrategy { goal, audience, content }
  snapshotId        String?
  snapshot          SegmentSnapshot? @relation(fields: [snapshotId], references: [id])
  metrics           CampaignMetrics?
  deliveries        DeliveryLog[]
  createdAt         DateTime @default(now())
}

model SegmentSnapshot {
  id          String   @id @default(uuid())
  customerIds String   // Stringified array of Customer IDs
  count       Int
  createdAt   DateTime @default(now())
  campaigns   Campaign[]
  customers   Customer[]
}

model CampaignMetrics {
  id           String   @id @default(uuid())
  sent         Int      @default(0)
  delivered    Int      @default(0)
  opened       Int      @default(0)
  clicked      Int      @default(0)
  conversions  Int      @default(0)
  revenue      Float    @default(0)
  campaignId   String   @unique
  campaign     Campaign @relation(fields: [campaignId], references: [id])
}

model DeliveryLog {
  id          String   @id @default(uuid())
  status      String   // SENT, DELIVERED, FAILED
  channel     String   // EMAIL, SMS, PUSH
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  timestamp   DateTime @default(now())
}
